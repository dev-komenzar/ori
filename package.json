{
  "name": "ori-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "ori (織) — DDD-driven feature scaffolding with CoDD coherence + per-feature TDD",
  "license": "MIT",
  "author": "Takuya Kometan <takuya.kometan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-komenzar/ori"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r run build",
    "build:skills": "node scripts/build-skills.mjs",
    "dev:skills": "node scripts/build-skills.mjs --watch",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "cli": "pnpm --filter @ori-ori/cli exec ori",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0",
    "lefthook": "^2.1.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
