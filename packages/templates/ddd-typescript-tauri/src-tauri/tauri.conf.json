{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ddd-typescript-tauri-app",
  "version": "0.0.0",
  "identifier": "com.example.ddd-typescript-tauri-app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm vite",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "title": "ddd-typescript-tauri-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
