{
  "name": "ddd-vsa-hex-typescript-tauri-app",
  "version": "0.0.0",
  "private": true,
  "description": "DDD-VSA-Hex Tauri project scaffolded from @ori-ori/templates/ddd-vsa-hex-typescript-tauri",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "arch:export:ts": "node ./.apm/skills/ori-arch/scripts/export.js --adapter=eslint --root=ts",
    "arch:export:rs": "node ./.apm/skills/ori-arch/scripts/export.js --adapter=rust --root=rs",
    "arch:export": "pnpm arch:export:ts && pnpm arch:export:rs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rs": "cd apps/template-app/src-tauri && cargo test",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "bindings:check": "pnpm tauri build --debug --no-bundle && git diff --exit-code apps/template-app/src/task-management/shared/ipc/bindings.ts"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  }
}
