{
  "name": "@ori-ori/templates",
  "version": "0.0.1",
  "description": "DDD code-generation templates for ori",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-komenzar/ori",
    "directory": "packages/templates"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["ddd-typescript", "ddd-typescript-tauri"],
  "exports": {
    "./ddd-typescript/*": "./ddd-typescript/*",
    "./ddd-typescript-tauri/*": "./ddd-typescript-tauri/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p ddd-typescript/tsconfig.json && tsc --noEmit -p ddd-typescript-tauri/tsconfig.json"
  },
  "devDependencies": {
    "@ori-ori/arch-adapter-eslint": "workspace:*",
    "@ori-ori/arch-adapter-rust": "workspace:*",
    "@ori-ori/parser": "workspace:*"
  }
}
