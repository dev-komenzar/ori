{
  "name": "@ori-ori/init-core",
  "version": "0.1.0",
  "description": "Core skeleton/scaffold logic for ori init (skill-callable without ori CLI)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-komenzar/ori",
    "directory": "packages/init-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "ori-init-skeleton": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ori-ori/slice-runner": "workspace:*",
    "yaml": "^2.5.0"
  }
}
