{
  "name": "@ori-ori/parser",
  "version": "0.2.0",
  "description": "Markdown / frontmatter / section parsing for ori",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-komenzar/ori",
    "directory": "packages/parser"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.0"
  }
}
