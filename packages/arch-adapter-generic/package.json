{
  "name": "@ori-ori/arch-adapter-generic",
  "version": "0.0.1",
  "description": "Language-neutral regex fallback adapter for ori arch (ts/js/py/rs/go)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-komenzar/ori",
    "directory": "packages/arch-adapter-generic"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ori-ori/parser": "workspace:*"
  }
}
